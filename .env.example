# =============================================================================
# IBM Watsonx Credentials
# =============================================================================
WATSONX_API_KEY=your_ibm_cloud_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_IOT=iot-sensor-events
KAFKA_CONSUMER_GROUP=lakehouse-pipeline

# =============================================================================
# MinIO (S3-compatible Object Storage)
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lakehouse
MINIO_SECURE=false

# =============================================================================
# Spark Configuration
# =============================================================================
SPARK_MASTER=local[*]
SPARK_APP_NAME=watsonx-lakehouse-pipeline
SPARK_WAREHOUSE_DIR=s3a://lakehouse/warehouse

# =============================================================================
# Lakehouse Paths
# =============================================================================
BRONZE_PATH=s3a://lakehouse/bronze
SILVER_PATH=s3a://lakehouse/silver
GOLD_PATH=s3a://lakehouse/gold

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080

# =============================================================================
# Streamlit Configuration
# =============================================================================
STREAMLIT_SERVER_PORT=8501
API_URL=http://localhost:8080
